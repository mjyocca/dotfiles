# .envrc — direnv project environment
# Copy to project root, uncomment as needed, then run: direnv allow

# ---------------------------------------------------------------------------
# asdf version export
# Exports ASDF_<LANG>_VERSION env vars from .tool-versions (or .go-version)
# into the direnv environment so subprocesses spawned by Neovim (e.g. Mason)
# inherit the correct language versions regardless of working directory.
# Remove this line if the project has no .tool-versions or .go-version file.
# ---------------------------------------------------------------------------
source ~/.asdf-direnv.sh

# ---------------------------------------------------------------------------
# Plugin gating (opt-in)
# These control whether heavy plugins are loaded at all.
# Must be set before Neovim starts — direnv handles this automatically.
# ---------------------------------------------------------------------------

# Load DAP + DAP UI for this project
# export NVIM_DAP_ENABLED=1

# ---------------------------------------------------------------------------
# Per-project Neovim config (alternative to .nvim.lua)
# Use when committing or gitignoring .nvim.lua at the project root is not
# practical. Point to any Lua file — relative paths resolve from project root.
# Sourced automatically on startup and on directory change.
# ---------------------------------------------------------------------------

# export NVIM_LOCAL_CONFIG=".config/nvim.lua"
