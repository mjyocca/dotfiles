#!/usr/bin/env bash
# Scaffold .envrc and .nvim.lua from Neovim project templates
# Usage: dotf nvim-project-init

set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Usage: dotf nvim-project-init"
  echo ""
  echo "Copies .envrc.template and .nvim.lua.template from the Neovim templates"
  echo "directory into the current working directory."
  echo ""
  echo "Templates are read from:"
  echo "  \${XDG_CONFIG_HOME:-\$HOME/.config}/nvim/templates/"
  exit 0
fi

template_dir="${XDG_CONFIG_HOME:-$HOME/.config}/nvim/templates"
errors=0

for file in .envrc .nvim.lua; do
  template="${template_dir}/${file}.template"
  dest="${PWD}/${file}"

  if [[ ! -f "$template" ]]; then
    echo "nvim-project-init: template not found: $template" >&2
    (( errors++ )) || true
    continue
  fi

  if [[ -f "$dest" ]]; then
    echo "  skip  ${file} (already exists)"
  else
    cp "$template" "$dest"
    echo "  wrote ${file}"
  fi
done

(( errors > 0 )) && exit 1 || true

echo ""
echo "Next steps:"
[[ -f "${PWD}/.envrc" ]] && echo "  direnv allow    # if using direnv"
echo "  edit .envrc     # uncomment env vars for this project"
echo "  edit .nvim.lua  # uncomment overrides for this project"
