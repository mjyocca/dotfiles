#!/usr/bin/env bash
# List colima profiles and their docker context status
# Usage: dotf colima-list

set -euo pipefail

info()    { echo "[INFO] $1"; }
warn()    { echo "[WARN] $1"; }
error()   { echo "[ERROR] $1" >&2; }
success() { echo "[OK] $1"; }

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Usage: dotf colima-list"
  echo ""
  echo "Lists all colima profiles with their run state, docker context, and socket path."
  exit 0
fi

if ! command -v colima &>/dev/null; then
  error "colima is not installed. Run: brew install colima"
  exit 1
fi

# Determine the currently active docker context
ACTIVE_CONTEXT="$(docker context show 2>/dev/null || echo "")"

# Header
printf "\n%-20s %-12s %-20s %s\n" "PROFILE" "STATE" "DOCKER CONTEXT" "SOCKET"
printf "%s\n" "$(printf '─%.0s' {1..80})"

# Discover profiles from ~/.colima (each subdirectory that is not _templates)
COLIMA_DIR="${HOME}/.colima"

if [[ ! -d "$COLIMA_DIR" ]]; then
  warn "No colima directory found at ${COLIMA_DIR}"
  exit 0
fi

found=0

for profile_dir in "$COLIMA_DIR"/*/; do
  profile="$(basename "$profile_dir")"

  # Skip internal directories
  [[ "$profile" == "_templates" ]] && continue
  [[ "$profile" == "._*" ]] && continue

  found=1

  # Derive context name
  if [[ "$profile" == "default" ]]; then
    context="colima"
  else
    context="colima-${profile}"
  fi

  # Get colima run state
  state="$(colima status "$profile" 2>&1 | grep -i "Running\|Stopped\|Not created" | head -1 | awk '{print $NF}' || echo "unknown")"
  if [[ -z "$state" ]]; then
    state="unknown"
  fi

  # Socket path
  socket="${COLIMA_DIR}/${profile}/docker.sock"
  if [[ -S "$socket" ]]; then
    socket_display="${socket}"
  else
    socket_display="(no socket)"
  fi

  # Mark active context
  active_marker=""
  if [[ "$context" == "$ACTIVE_CONTEXT" ]]; then
    active_marker=" *"
  fi

  printf "%-20s %-12s %-20s %s%s\n" \
    "$profile" \
    "$state" \
    "${context}${active_marker}" \
    "$socket_display"
done

if [[ "$found" -eq 0 ]]; then
  warn "No colima profiles found. Start one with: colima start [profile]"
fi

echo ""
info "Active docker context: ${ACTIVE_CONTEXT}"
echo ""
echo "Switch profile: dotf colima-use <profile>"
