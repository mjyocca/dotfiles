.DS_STORE

.scratch

.env
.envrc

# Per-machine zsh overrides — not committed
packages/zsh/.zshrc.local

# Per-machine stow ignore list — not committed
.stow-ignore.local

# Colima: ignore all runtime envs, keep tracked example config
packages/colima/.colima/**
!packages/colima/.colima/
!packages/colima/.colima/_templates/
!packages/colima/.colima/_templates/default.yaml
